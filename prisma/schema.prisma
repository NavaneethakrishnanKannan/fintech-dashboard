
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  createdAt DateTime @default(now())
  loans     Loan[]
  expenses  Expense[]
  investments Investment[]
  incomes     Income[]
  chatMessages ChatMessage[]
  goals        Goal[]
  passwordResetTokens PasswordResetToken[]
  alerts     Alert[]
  netWorthHistories NetWorthHistory[]
  zerodhaConnection ZerodhaConnection?
}

model ZerodhaConnection {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken String   // Kite access token (expires ~6 AM next day)
  kiteUserId  String?  // Zerodha user id (e.g. AB1234)
  userName    String?  // Name from Kite profile
  connectedAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id                String    @id @default(cuid())
  title             String
  targetAmount      Float
  currentAmount     Float     @default(0)
  targetDate        DateTime?
  expectedReturnRate Float?   // annual expected return %
  createdAt         DateTime  @default(now())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Loan {
  id                String   @id @default(cuid())
  name              String
  principal         Float
  interest          Float   // annual interest rate (%)
  tenure            Int     // remaining months (months left)
  totalTenureMonths Int?    // original total tenure in months (optional)
  emi               Float
  startDate         DateTime
  userId            String
  user              User     @relation(fields: [userId], references: [id])
}

model Expense {
  id        String   @id @default(cuid())
  amount     Float
  category   String
  description String?
  date       DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
}

model Investment {
  id           String   @id @default(cuid())
  type         String   // stock, mutual_fund, crypto, etc.
  symbol       String?
  name         String
  quantity     Float
  buyPrice     Float
  currentPrice Float?   // optional; if null, current value = buyPrice + profit
  profit       Float    @default(0)
  buyDate      DateTime
  monthlySip   Float?   // optional monthly SIP/contribution (₹)
  sector       String?  // optional sector
  category     String?  // equity, debt, gold
  userId       String
  user         User     @relation(fields: [userId], references: [id])
}

model Income {
  id        String   @id @default(cuid())
  amount    Float
  category  String   // Salary, Bonus, Other
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Alert {
  id        String   @id @default(cuid())
  userId    String
  type      String   // expense_budget, low_savings, high_loan_ratio, concentrated_portfolio, etc.
  title     String
  message   String
  severity  String?  // info, warning, error
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NetWorthHistory {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime // snapshot date (e.g. end of day)
  assets     Float
  liabilities Float
  netWorth   Float
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
