# Database (Neon or Supabase PostgreSQL)
# Use pooled URL for the app. With Supabase/pooler you MUST add ?pgbouncer=true to avoid
# "prepared statement does not exist" errors (Prisma + connection pooler).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?pgbouncer=true"

# REQUIRED for migrations: use a DIRECT (non-pooled) connection (no pgbouncer param).
# Supabase: use "Session mode" / direct connection (port 5432 to db.PROJECT_REF.supabase.co).
DIRECT_URL="postgresql://..."

# Disable advisory lock so migrate deploy/resolve don't timeout (e.g. with Supabase pooler or concurrent connections).
# Set to 1 when running: npx prisma migrate deploy / migrate resolve / migrate dev
PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# For Vercel/production set to your deployment URL, e.g. https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional – for Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI (Gemini and/or Groq for Financial Advisor)
GEMINI_API_KEY=""
GROQ_API_KEY=""

# Zerodha Kite Connect (optional – for linking Zerodha portfolio)
# Get api_key and api_secret from https://developers.kite.trade/
# Redirect URL must be set in Kite developer console to: NEXTAUTH_URL/api/zerodha/callback
KITE_API_KEY=""
KITE_API_SECRET=""
